{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Medicoo",
  "version": "1.0.0",
  "identifier": "pk.medicoo.pos",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Medicoo — Pharmacy POS",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "theme": "Light"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Taufeeq Laghari",
    "copyright": "© 2026 Medicoo · Services by Taufeeq Laghari",
    "category": "Business",
    "shortDescription": "Pharmacy POS System for Pakistan",
    "longDescription": "Medicoo is a complete offline-first Pharmacy POS with billing, inventory, udhaar, multi-branch support, GST compliance, English/Urdu, and thermal receipt printing — built for Pakistani pharmacies.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["en-US"]
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      }
    }
  }
}
